# Showcase-only overrides (optional).
# Scan + shared backend credentials load automatically from ../FareShare/.env.local.
# Only add keys here when this site needs different values than the main app.
#
# Examples (uncomment and fill only if needed):
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# RATE_LIMIT_SALT=
#
# Public site URL used for SEO (metadataBase, sitemap, canonicals) and waitlist links (required in production):
# SHOWCASE_SITE_URL=https://fareshare.app
#
# Waitlist email (required in production). Reuses FareShare Outlook SMTP by default:
# WAITLIST_SMTP_USER=
# WAITLIST_SMTP_PASSWORD=
# WAITLIST_FROM_EMAIL=hello@fareshare.app
# WAITLIST_SMTP_HOST=smtp.office365.com
# WAITLIST_SMTP_PORT=587
#
# Waitlist anti-spam (required in production — free via Cloudflare dashboard):
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=
#
# Receipt scan demo — keep unset/false on the public showcase (API is disabled regardless):
# RECEIPT_SCAN_DEMO_ENABLED=false
